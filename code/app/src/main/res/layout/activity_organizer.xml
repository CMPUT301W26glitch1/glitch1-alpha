<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="15sp">

    <TextView
        android:id="@+id/organizerMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Organizer Menu"
        android:textSize="35sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/createEventBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Create Event"
        android:layout_marginBottom="5dp"/>

    <Button
        android:id="@+id/updatePosterBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Update Poster"
        android:layout_marginBottom="5dp"/>

    <Button
        android:id="@+id/WaitingListBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="View Waiting List"
        android:layout_marginBottom="5dp"/>

    <Button
        android:id="@+id/MapBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="View Entrant Map"
        android:layout_marginBottom="5dp"/>

    <Button
        android:id="@+id/NotificationBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Send Notifications"/>

</LinearLayout>