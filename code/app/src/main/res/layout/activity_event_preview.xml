<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="15dp">

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/eventPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Event Preview"
            android:textSize="35sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Event Poster"
            android:textSize="23sp"
            android:layout_marginTop="15dp"/>

        <ImageView
            android:id="@+id/previewPoster"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="5dp"
            android:scaleType="fitStart"
            android:src="@android:drawable/ic_menu_gallery" />

        <TextView
            android:id="@+id/previewTitle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Event Title"
            android:layout_marginTop="12dp"
            android:textSize="23sp"/>

        <TextView
            android:id="@+id/previewDescription"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Event Description"
            android:textSize="23sp"/>

        <TextView
            android:id="@+id/previewLocation"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Event Location"
            android:textSize="23sp"/>

        <TextView
            android:id="@+id/previewTime"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Event Time"
            android:textSize="23sp"/>

        <TextView
            android:id="@+id/previewRegStart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Registration Start"
            android:textSize="23sp"/>

        <TextView
            android:id="@+id/previewRegEnd"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Registration End"
            android:textSize="23sp"/>

        <Button
            android:id="@+id/eventButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5sp"
            android:text="Create Event"/>

    </LinearLayout>

</ScrollView>